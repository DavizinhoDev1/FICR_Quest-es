#include <stdio.h>
#define PI 3.14
int main() {
    
    float r, h, area, volume;
    
    
    printf("Digite o valor do raio: ");
    scanf("%f", &r);
    
    
    printf("Digite o valor da Altura: ");
    scanf("%f", &h);
    
    
    area = 2 * 3.14 * r * (h + r);
    volume = 3.14 * r * r * h;
    
	printf("Area:%.2f\n", area);    
	printf("volume:%.2f\n", volume);
    
    return 0;
}
